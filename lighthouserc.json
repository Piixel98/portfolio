{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": ["http://localhost:4173/"],
      "numberOfRuns": 1,
      "settings": {
        "budgets": [
          {
            "path": "/*",
            "resourceSizes": [
              { "resourceType": "script", "budget": 180 },
              { "resourceType": "stylesheet", "budget": 40 },
              { "resourceType": "image", "budget": 80 },
              { "resourceType": "font", "budget": 120 },
              { "resourceType": "total", "budget": 500 }
            ],
            "timings": [
              { "metric": "first-contentful-paint", "budget": 1800 },
              { "metric": "largest-contentful-paint", "budget": 2500 },
              { "metric": "total-blocking-time", "budget": 200 },
              { "metric": "cumulative-layout-shift", "budget": 0.1 }
            ]
          }
        ]
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }],
        "categories:performance": ["warn", { "minScore": 0.85 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "resource-summary:script:size": ["warn", { "maxNumericValue": 184320 }],
        "resource-summary:stylesheet:size": ["warn", { "maxNumericValue": 40960 }],
        "total-byte-weight": ["warn", { "maxNumericValue": 512000 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
